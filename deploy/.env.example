# n8n Production Environment
# Copy to .env and fill in values

# Domain
N8N_DOMAIN=n8n.colorverse.dev

# PostgreSQL
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# n8n Encryption Key (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL
